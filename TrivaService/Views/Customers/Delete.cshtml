@model Customer
@{
    ViewData["Title"] = "Delete customer";
}
<h1>Delete customer</h1>
<p class="text-danger">Are you sure you want to delete this record?</p>
<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Id)</dt><dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.CustomerName)</dt><dd class="col-sm-10">@Model.CustomerName</dd>
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.CustomerPhone)</dt><dd class="col-sm-10">@Model.CustomerPhone</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
