@model Customer
@{
    ViewData["Title"] = "Müşteri Detayları";
}

<div class="page-header">
    <h1>Müşteri Detayları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Müşteri Adı</dt><dd class="col-sm-9">@Model.CustomerName</dd>
            <dt class="col-sm-3">Telefon</dt><dd class="col-sm-9">@Model.CustomerPhone</dd>
            <dt class="col-sm-3">Adres</dt><dd class="col-sm-9">@(Model.CustomerAddress ?? "—")</dd>
            <dt class="col-sm-3">Notlar</dt><dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
            <dt class="col-sm-3">Son Servis Tarihi</dt><dd class="col-sm-9">@(Model.LastServiceDate?.ToString("g") ?? "—")</dd>
            <dt class="col-sm-3">Toplam Servis</dt><dd class="col-sm-9">@Model.TotalServiceCount</dd>
            <dt class="col-sm-3">Oluşturma Tarihi</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Güncelleme Tarihi</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Aktif</span>
                }
                else
                {
                    <span class="badge-inactive">Pasif</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Düzenle</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Sil</a>
</div>
