@model IEnumerable<Service>
@{
    ViewData["Title"] = "Servisler";
}

<div class="page-header">
    <h1>Servisler</h1>
    <div class="d-flex gap-2 align-items-center">
        <div class="dropdown">
            <button class="btn filter-toggle-btn" type="button" id="filterToggle"
                    data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                </svg>
                Filtrele
                <span class="filter-count-badge" id="filterBadge" style="display:none">0</span>
            </button>
            <div class="dropdown-menu filter-dropdown-menu dropdown-menu-end" aria-labelledby="filterToggle">
                <div class="fp-header">
                    <span class="fp-title">Filtrele</span>
                    <a asp-action="Index" class="fp-clear">Temizle</a>
                </div>
                <form id="filterForm" novalidate>
                    <div class="filter-dropdown-grid">
                        <div class="fp-dd-field">
                            <label class="fp-dd-label">Servis Kodu</label>
                            <input type="text" class="form-control" id="filter_ServiceCode" placeholder="Ara...">
                        </div>
                        <div class="fp-dd-field">
                            <label class="fp-dd-label">Durum</label>
                            <input type="text" class="form-control" id="filter_Status" placeholder="Ara...">
                        </div>
                        <div class="fp-dd-field">
                            <label class="fp-dd-label">Arıza Açıklaması</label>
                            <input type="text" class="form-control" id="filter_FaultDescription" placeholder="Ara...">
                        </div>
                        <div class="fp-dd-field">
                            <label class="fp-dd-label">Servis Adresi</label>
                            <input type="text" class="form-control" id="filter_ServiceAddress" placeholder="Ara...">
                        </div>
                        <div class="fp-dd-field" style="grid-column: 1 / -1;">
                            <label class="fp-dd-label">Aktiflik</label>
                            <select class="form-select" id="filter_IsActive">
                                <option value="">Tümü</option>
                                <option value="true">Aktif</option>
                                <option value="false">Pasif</option>
                            </select>
                        </div>
                    </div>
                    <div class="fp-actions">
                        <button type="submit" class="btn btn-primary flex-fill">Filtrele</button>
                    </div>
                </form>
            </div>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Yeni Servis</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kod</th>
                    <th>Durum</th>
                    <th>Müşteri</th>
                    <th>Alınma Tarihi</th>
                    <th>Tahmini Maliyet</th>
                    <th>Aktiflik</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status switch
                    {
                        "Completed" => "bg-success",
                        "In Progress" => "bg-info",
                        "Cancelled" => "bg-danger",
                        _ => "bg-warning text-dark"
                    };
                    <tr>
                        <td class="text-muted">@item.Id</td>
                        <td class="fw-semibold">@item.ServiceCode</td>
                        <td><span class="badge @statusClass">@item.Status</span></td>
                        <td>@(item.CustomerId?.ToString() ?? "—")</td>
                        <td class="text-muted">@item.ReceivedDate.ToString("d")</td>
                        <td>@(item.EstimatedCost?.ToString("C") ?? "—")</td>
                        <td>
                            @if (item.IsActive) { <span class="badge-active">Aktif</span> }
                            else { <span class="badge-inactive">Pasif</span> }
                        </td>
                        <td class="action-btns text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detaylar</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Kayıt bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var raw    = @Json.Serialize((string)(ViewBag.CurrentFilter ?? ""));
    var badge  = document.getElementById('filterBadge');
    var toggle = document.getElementById('filterToggle');
    var ids    = ['filter_ServiceCode','filter_Status','filter_FaultDescription','filter_ServiceAddress','filter_IsActive'];

    function pc(f, n) {
        if (!f) return '';
        var re = new RegExp('contains\\(\\s*' + n.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\s*,\\s*\'([^\']*)\'\\)','i');
        var m = f.match(re); return m ? m[1].replace(/''/g,"'") : '';
    }
    function pe(f, n) {
        if (!f) return '';
        var re = new RegExp('\\b' + n.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\s+eq\\s+(?:\'([^\']*)\'|([^\\s)&|]+))','i');
        var m = f.match(re); if (!m) return '';
        return (m[1] !== undefined ? m[1] : (m[2]||'')).trim();
    }

    document.getElementById('filter_ServiceCode').value      = pc(raw,'ServiceCode');
    document.getElementById('filter_Status').value           = pc(raw,'Status');
    document.getElementById('filter_FaultDescription').value = pc(raw,'FaultDescription');
    document.getElementById('filter_ServiceAddress').value   = pc(raw,'ServiceAddress');
    document.getElementById('filter_IsActive').value         = pe(raw,'IsActive');

    function updateBadge() {
        var n = ids.filter(function(id){ var el=document.getElementById(id); return el&&el.value.trim(); }).length;
        badge.textContent = n; badge.style.display = n ? 'inline-flex' : 'none';
        n ? toggle.classList.add('has-filters') : toggle.classList.remove('has-filters');
    }
    updateBadge();
    ids.forEach(function(id){ var el=document.getElementById(id); if(el){ el.addEventListener('input',updateBadge); el.addEventListener('change',updateBadge); } });

    document.getElementById('filterForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var parts = [], v;
        v = document.getElementById('filter_ServiceCode').value.trim();
        if (v) parts.push("contains(ServiceCode,'" + v.replace(/'/g,"''") + "')");
        v = document.getElementById('filter_Status').value.trim();
        if (v) parts.push("contains(Status,'" + v.replace(/'/g,"''") + "')");
        v = document.getElementById('filter_FaultDescription').value.trim();
        if (v) parts.push("contains(FaultDescription,'" + v.replace(/'/g,"''") + "')");
        v = document.getElementById('filter_ServiceAddress').value.trim();
        if (v) parts.push("contains(ServiceAddress,'" + v.replace(/'/g,"''") + "')");
        v = document.getElementById('filter_IsActive').value;
        if (v) parts.push('IsActive eq ' + v);
        window.location.href = window.location.pathname + (parts.length ? '?$filter=' + encodeURIComponent(parts.join(' and ')) : '');
    });
})();
</script>
}
