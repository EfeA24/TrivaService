@model IEnumerable<Service>
@{
    ViewData["Title"] = "Services";
}

<div class="page-header">
    <h1>Services</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Service</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Code</th>
                    <th>Status</th>
                    <th>Customer</th>
                    <th>Received</th>
                    <th>Est. Cost</th>
                    <th>Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status switch
                    {
                        "Completed" => "bg-success",
                        "In Progress" => "bg-info",
                        "Cancelled" => "bg-danger",
                        _ => "bg-warning text-dark"
                    };

                    <tr>
                        <td class="text-muted">@item.Id</td>
                        <td class="fw-semibold">@item.ServiceCode</td>
                        <td>
                            <span class="badge @statusClass">@item.Status</span>
                        </td>
                        <td>@(item.CustomerId?.ToString() ?? "—")</td>
                        <td class="text-muted">@item.ReceivedDate.ToString("d")</td>
                        <td>@(item.EstimatedCost?.ToString("C") ?? "—")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td class="action-btns text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No services found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
