@model IEnumerable<Service>
@{
    ViewData["Title"] = "Servisler";
}

<div class="index-layout">
    <div class="index-main">
        <div class="page-header">
            <h1>Servisler</h1>
            <a asp-action="Create" class="btn btn-primary">+ Yeni Servis</a>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Kod</th>
                            <th>Durum</th>
                            <th>Müşteri</th>
                            <th>Alınma Tarihi</th>
                            <th>Tahmini Maliyet</th>
                            <th>Aktiflik</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusClass = item.Status switch
                            {
                                "Completed" => "bg-success",
                                "In Progress" => "bg-info",
                                "Cancelled" => "bg-danger",
                                _ => "bg-warning text-dark"
                            };

                            <tr>
                                <td class="text-muted">@item.Id</td>
                                <td class="fw-semibold">@item.ServiceCode</td>
                                <td>
                                    <span class="badge @statusClass">@item.Status</span>
                                </td>
                                <td>@(item.CustomerId?.ToString() ?? "—")</td>
                                <td class="text-muted">@item.ReceivedDate.ToString("d")</td>
                                <td>@(item.EstimatedCost?.ToString("C") ?? "—")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-active">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Pasif</span>
                                    }
                                </td>
                                <td class="action-btns text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detaylar</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Kayıt bulunamadı.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <aside class="filter-panel" id="filterPanel">
        <div class="fp-header">
            <span class="fp-title">Filtrele</span>
            <a asp-action="Index" class="fp-clear">Temizle</a>
        </div>
        <form id="filterForm" novalidate>
            <div class="fp-field">
                <label class="fp-label">Servis Kodu</label>
                <input type="text" class="form-control form-control-sm" id="filter_ServiceCode" placeholder="Ara...">
            </div>
            <div class="fp-field">
                <label class="fp-label">Durum</label>
                <input type="text" class="form-control form-control-sm" id="filter_Status" placeholder="Ara...">
            </div>
            <div class="fp-field">
                <label class="fp-label">Arıza Açıklaması</label>
                <input type="text" class="form-control form-control-sm" id="filter_FaultDescription" placeholder="Ara...">
            </div>
            <div class="fp-field">
                <label class="fp-label">Servis Adresi</label>
                <input type="text" class="form-control form-control-sm" id="filter_ServiceAddress" placeholder="Ara...">
            </div>
            <div class="fp-field">
                <label class="fp-label">Aktiflik</label>
                <select class="form-select form-select-sm" id="filter_IsActive">
                    <option value="">Tümü</option>
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>
            <div class="fp-actions">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">Filtrele</button>
            </div>
        </form>
    </aside>
</div>

@section Scripts {
<script>
(function () {
    var raw = @Json.Serialize((string)(ViewBag.CurrentFilter ?? ""));

    function pc(f, n) {
        if (!f) return '';
        var re = new RegExp('contains\\(\\s*' + n.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\s*,\\s*\'([^\']*)\'\\)', 'i');
        var m = f.match(re);
        return m ? m[1].replace(/''/g, "'") : '';
    }

    function pe(f, n) {
        if (!f) return '';
        var re = new RegExp('\\b' + n.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\s+eq\\s+(?:\'([^\']*)\'|([^\\s)&|]+))', 'i');
        var m = f.match(re);
        if (!m) return '';
        return (m[1] !== undefined ? m[1] : (m[2] || '')).trim();
    }

    document.getElementById('filter_ServiceCode').value     = pc(raw, 'ServiceCode');
    document.getElementById('filter_Status').value          = pc(raw, 'Status');
    document.getElementById('filter_FaultDescription').value = pc(raw, 'FaultDescription');
    document.getElementById('filter_ServiceAddress').value  = pc(raw, 'ServiceAddress');
    document.getElementById('filter_IsActive').value        = pe(raw, 'IsActive');

    document.getElementById('filterForm').addEventListener('submit', function (e) {
        e.preventDefault();
        var parts = [];
        var v;
        v = document.getElementById('filter_ServiceCode').value.trim();
        if (v) parts.push("contains(ServiceCode,'" + v.replace(/'/g, "''") + "')");
        v = document.getElementById('filter_Status').value.trim();
        if (v) parts.push("contains(Status,'" + v.replace(/'/g, "''") + "')");
        v = document.getElementById('filter_FaultDescription').value.trim();
        if (v) parts.push("contains(FaultDescription,'" + v.replace(/'/g, "''") + "')");
        v = document.getElementById('filter_ServiceAddress').value.trim();
        if (v) parts.push("contains(ServiceAddress,'" + v.replace(/'/g, "''") + "')");
        v = document.getElementById('filter_IsActive').value;
        if (v) parts.push('IsActive eq ' + v);
        var qs = parts.length ? '?$filter=' + encodeURIComponent(parts.join(' and ')) : '';
        window.location.href = window.location.pathname + qs;
    });
})();
</script>
}
