@model Service
@{
    ViewData["Title"] = "Yeni Servis";
}

<div class="page-header">
    <h1>Yeni Servis</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm form-card wide">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <p class="form-section-title">Servis Bilgileri</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Müşteri</label>
                    <input asp-for="CustomerId" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ServiceCode" class="form-label fw-semibold">Servis Kodu</label>
                    <input asp-for="ServiceCode" class="form-control" />
                    <span asp-validation-for="ServiceCode" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Status" class="form-label fw-semibold">Durum</label>
                    <input asp-for="Status" class="form-control" />
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="ServiceAddress" class="form-label fw-semibold">Servis Adresi</label>
                    <input asp-for="ServiceAddress" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="FaultDescription" class="form-label fw-semibold">Arıza Açıklaması</label>
                    <textarea asp-for="FaultDescription" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="FaultDescription" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ServiceDescription" class="form-label fw-semibold">Servis Açıklaması</label>
                    <textarea asp-for="ServiceDescription" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="ServiceNotes" class="form-label fw-semibold">Notlar</label>
                    <textarea asp-for="ServiceNotes" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <p class="form-section-title mt-4">Tarihler</p>
            <div class="row g-3">
                <div class="col-sm-4">
                    <label asp-for="ReceivedDate" class="form-label fw-semibold">Alınma Tarihi</label>
                    <input asp-for="ReceivedDate" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="CompletedDate" class="form-label fw-semibold">Tamamlanma Tarihi</label>
                    <input asp-for="CompletedDate" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="DeliveredDate" class="form-label fw-semibold">Teslim Tarihi</label>
                    <input asp-for="DeliveredDate" class="form-control" />
                </div>
            </div>

            <p class="form-section-title mt-4">Servis Süresi</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ServiceDurationDays" class="form-label fw-semibold">Gün</label>
                    <input asp-for="ServiceDurationDays" class="form-control" type="number" min="0" placeholder="ör. 2" />
                    <span asp-validation-for="ServiceDurationDays" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="ServiceDurationHours" class="form-label fw-semibold">Saat <span class="text-muted fw-normal">(opsiyonel)</span></label>
                    <input asp-for="ServiceDurationHours" class="form-control" type="number" min="0" max="23" placeholder="0-23" />
                    <span asp-validation-for="ServiceDurationHours" class="text-danger small"></span>
                </div>
            </div>

            <p class="form-section-title mt-4">Maliyetler</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="EstimatedCost" class="form-label fw-semibold">Tahmini Maliyet</label>
                    <input asp-for="EstimatedCost" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="FinalCost" class="form-label fw-semibold">Nihai Maliyet</label>
                    <input asp-for="FinalCost" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsPaymentComplete" class="form-check-input" />
                        <label asp-for="IsPaymentComplete" class="form-check-label fw-semibold">Ödeme Tamamlandı</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
