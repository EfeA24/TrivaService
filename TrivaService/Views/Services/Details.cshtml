@model Service
@{
    ViewData["Title"] = "Servis Detayları";
    var statusClass = Model.Status switch
    {
        "Completed" => "bg-success",
        "In Progress" => "bg-info",
        "Cancelled" => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<div class="page-header">
    <h1>Servis Detayları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Servis Kodu</dt><dd class="col-sm-9">@Model.ServiceCode</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9"><span class="badge @statusClass">@Model.Status</span></dd>
            <dt class="col-sm-3">Müşteri</dt><dd class="col-sm-9">@(Model.CustomerId?.ToString() ?? "—")</dd>
            <dt class="col-sm-3">Servis Adresi</dt><dd class="col-sm-9">@(Model.ServiceAddress ?? "—")</dd>
            <dt class="col-sm-3">Arıza Açıklaması</dt><dd class="col-sm-9">@Model.FaultDescription</dd>
            <dt class="col-sm-3">Servis Açıklaması</dt><dd class="col-sm-9">@(Model.ServiceDescription ?? "—")</dd>
            <dt class="col-sm-3">Notlar</dt><dd class="col-sm-9">@(Model.ServiceNotes ?? "—")</dd>
            <dt class="col-sm-3">Alınma Tarihi</dt><dd class="col-sm-9">@Model.ReceivedDate.ToString("g")</dd>
            <dt class="col-sm-3">Tamamlanma Tarihi</dt><dd class="col-sm-9">@(Model.CompletedDate?.ToString("g") ?? "—")</dd>
            <dt class="col-sm-3">Teslim Tarihi</dt><dd class="col-sm-9">@(Model.DeliveredDate?.ToString("g") ?? "—")</dd>
            <dt class="col-sm-3">Tahmini Maliyet</dt><dd class="col-sm-9">@(Model.EstimatedCost?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Nihai Maliyet</dt><dd class="col-sm-9">@(Model.FinalCost?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Ödeme</dt>
            <dd class="col-sm-9">
                @if (Model.IsPaymentComplete)
                {
                    <span class="badge bg-success">Ödendi</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Ödenmedi</span>
                }
            </dd>
            <dt class="col-sm-3">Oluşturma Tarihi</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Güncelleme Tarihi</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Aktiflik</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Aktif</span>
                }
                else
                {
                    <span class="badge-inactive">Pasif</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Düzenle</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Sil</a>
</div>
