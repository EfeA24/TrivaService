@model Service
@{
    ViewData["Title"] = "Service Details";
    var statusClass = Model.Status switch
    {
        "Completed" => "bg-success",
        "In Progress" => "bg-info",
        "Cancelled" => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<div class="page-header">
    <h1>Service Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Code</dt><dd class="col-sm-9">@Model.ServiceCode</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge @statusClass">@Model.Status</span></dd>
            <dt class="col-sm-3">Customer</dt><dd class="col-sm-9">@(Model.CustomerId?.ToString() ?? "—")</dd>
            <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@(Model.ServiceAddress ?? "—")</dd>
            <dt class="col-sm-3">Fault</dt><dd class="col-sm-9">@Model.FaultDescription</dd>
            <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@(Model.ServiceDescription ?? "—")</dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@(Model.ServiceNotes ?? "—")</dd>
            <dt class="col-sm-3">Received</dt><dd class="col-sm-9">@Model.ReceivedDate.ToString("g")</dd>
            <dt class="col-sm-3">Completed</dt><dd class="col-sm-9">@(Model.CompletedDate?.ToString("g") ?? "—")</dd>
            <dt class="col-sm-3">Delivered</dt><dd class="col-sm-9">@(Model.DeliveredDate?.ToString("g") ?? "—")</dd>
            <dt class="col-sm-3">Est. Cost</dt><dd class="col-sm-9">@(Model.EstimatedCost?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Final Cost</dt><dd class="col-sm-9">@(Model.FinalCost?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Payment</dt>
            <dd class="col-sm-9">
                @if (Model.IsPaymentComplete)
                {
                    <span class="badge bg-success">Paid</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Unpaid</span>
                }
            </dd>
            <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Updated</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
</div>
