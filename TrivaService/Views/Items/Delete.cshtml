@model Item
@{
    ViewData["Title"] = "Delete Item";
}

<div class="page-header">
    <h1 class="text-danger">Delete Item</h1>
</div>

<div class="card border-danger shadow-sm" style="max-width: 560px;">
    <div class="card-header bg-danger text-white fw-semibold">
        This action cannot be undone. Are you sure?
    </div>
    <div class="card-body">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-4">ID</dt><dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.ItemName</dd>
            <dt class="col-sm-4">Code</dt><dd class="col-sm-8">@(Model.ItemCode ?? "—")</dd>
            <dt class="col-sm-4">Brand</dt><dd class="col-sm-8">@(Model.ItemBrand ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer bg-transparent d-flex gap-2">
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
