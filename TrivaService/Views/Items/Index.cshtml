@model IEnumerable<Item>
@{
    ViewData["Title"] = "Items";
}

<div class="page-header">
    <h1>Items</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Item</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Brand</th>
                    <th>Type</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">@item.Id</td>
                        <td class="fw-semibold">@item.ItemName</td>
                        <td class="text-muted">@(item.ItemCode ?? "—")</td>
                        <td>@(item.ItemBrand ?? "—")</td>
                        <td>@(item.ItemType ?? "—")</td>
                        <td>@item.ItemQuantity</td>
                        <td>@(item.ItemPrice?.ToString("C") ?? "—")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td class="action-btns text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">No items found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
