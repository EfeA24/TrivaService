@model Item
@{
    ViewData["Title"] = "Edit Item";
}

<div class="page-header">
    <h1>Edit Item</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm form-card wide">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <p class="form-section-title">Identification</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ItemName" class="form-label fw-semibold"></label>
                    <input asp-for="ItemName" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ItemCode" class="form-label fw-semibold"></label>
                    <input asp-for="ItemCode" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="ItemBrand" class="form-label fw-semibold"></label>
                    <input asp-for="ItemBrand" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="ItemModel" class="form-label fw-semibold"></label>
                    <input asp-for="ItemModel" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="ItemType" class="form-label fw-semibold"></label>
                    <input asp-for="ItemType" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ItemBarcode" class="form-label fw-semibold"></label>
                    <input asp-for="ItemBarcode" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="SupplierId" class="form-label fw-semibold"></label>
                    <input asp-for="SupplierId" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="ItemDescription" class="form-label fw-semibold"></label>
                    <textarea asp-for="ItemDescription" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <p class="form-section-title mt-4">Stock</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ItemQuantity" class="form-label fw-semibold"></label>
                    <input asp-for="ItemQuantity" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ItemPrice" class="form-label fw-semibold"></label>
                    <input asp-for="ItemPrice" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
