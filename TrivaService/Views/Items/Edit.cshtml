@model Item
@{
    ViewData["Title"] = "Edit item";
}
<h1>Edit item</h1>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="SupplierId" class="form-label"></label>
        <input asp-for="SupplierId" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemName" class="form-label"></label>
        <input asp-for="ItemName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemCode" class="form-label"></label>
        <input asp-for="ItemCode" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemBrand" class="form-label"></label>
        <input asp-for="ItemBrand" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemModel" class="form-label"></label>
        <input asp-for="ItemModel" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemBarcode" class="form-label"></label>
        <input asp-for="ItemBarcode" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemDescription" class="form-label"></label>
        <textarea asp-for="ItemDescription" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="ItemType" class="form-label"></label>
        <input asp-for="ItemType" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemQuantity" class="form-label"></label>
        <input asp-for="ItemQuantity" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ItemPrice" class="form-label"></label>
        <input asp-for="ItemPrice" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
