@model Item
@{
    ViewData["Title"] = "Ürün Detayları";
}

<div class="page-header">
    <h1>Ürün Detayları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Ürün Adı</dt><dd class="col-sm-9">@Model.ItemName</dd>
            <dt class="col-sm-3">Ürün Kodu</dt><dd class="col-sm-9">@(Model.ItemCode ?? "—")</dd>
            <dt class="col-sm-3">Marka</dt><dd class="col-sm-9">@(Model.ItemBrand ?? "—")</dd>
            <dt class="col-sm-3">Model</dt><dd class="col-sm-9">@(Model.ItemModel ?? "—")</dd>
            <dt class="col-sm-3">Barkod</dt><dd class="col-sm-9">@(Model.ItemBarcode ?? "—")</dd>
            <dt class="col-sm-3">Tür</dt><dd class="col-sm-9">@(Model.ItemType ?? "—")</dd>
            <dt class="col-sm-3">Açıklama</dt><dd class="col-sm-9">@(Model.ItemDescription ?? "—")</dd>
            <dt class="col-sm-3">Tedarikçi</dt><dd class="col-sm-9">@Model.SupplierId</dd>
            <dt class="col-sm-3">Adet</dt><dd class="col-sm-9">@Model.ItemQuantity</dd>
            <dt class="col-sm-3">Fiyat</dt><dd class="col-sm-9">@(Model.ItemPrice?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Oluşturma Tarihi</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Güncelleme Tarihi</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Aktif</span>
                }
                else
                {
                    <span class="badge-inactive">Pasif</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Düzenle</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Sil</a>
</div>
