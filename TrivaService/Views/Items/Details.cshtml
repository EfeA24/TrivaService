@model Item
@{
    ViewData["Title"] = "Item Details";
}

<div class="page-header">
    <h1>Item Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.ItemName</dd>
            <dt class="col-sm-3">Code</dt><dd class="col-sm-9">@(Model.ItemCode ?? "—")</dd>
            <dt class="col-sm-3">Brand</dt><dd class="col-sm-9">@(Model.ItemBrand ?? "—")</dd>
            <dt class="col-sm-3">Model</dt><dd class="col-sm-9">@(Model.ItemModel ?? "—")</dd>
            <dt class="col-sm-3">Barcode</dt><dd class="col-sm-9">@(Model.ItemBarcode ?? "—")</dd>
            <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@(Model.ItemType ?? "—")</dd>
            <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@(Model.ItemDescription ?? "—")</dd>
            <dt class="col-sm-3">Supplier</dt><dd class="col-sm-9">@Model.SupplierId</dd>
            <dt class="col-sm-3">Quantity</dt><dd class="col-sm-9">@Model.ItemQuantity</dd>
            <dt class="col-sm-3">Price</dt><dd class="col-sm-9">@(Model.ItemPrice?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Updated</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
</div>
