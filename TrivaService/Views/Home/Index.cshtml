@model DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Ana Sayfa";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
}

<div class="page-header">
    <h1>Ana Sayfa</h1>
</div>

<form id="dashHomeFilters" method="get" asp-controller="Home" asp-action="Index" class="d-none" aria-hidden="true"></form>

<div class="page-header pt-0 border-0 pb-2 mb-3">
    <h2 class="h5 mb-3">Hızlı erişim</h2>
</div>
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Customers" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-primary bg-opacity-10 text-primary">&#128100;</div>
                <div class="fw-semibold">Müşteriler</div>
                <div class="text-muted small">Müşteri kayıtlarını yönetin</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Services" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-success bg-opacity-10 text-success">&#128295;</div>
                <div class="fw-semibold">Hizmetler</div>
                <div class="text-muted small">Hizmetleri görüntüleyin ve yönetin</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Items" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-warning bg-opacity-10 text-warning">&#128230;</div>
                <div class="fw-semibold">Ürünler</div>
                <div class="text-muted small">Stok ve envanter</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Suppliers" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-info bg-opacity-10 text-info">&#127968;</div>
                <div class="fw-semibold">Tedarikçiler</div>
                <div class="text-muted small">Tedarikçileri yönetin</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="ServiceItems" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-secondary bg-opacity-10 text-secondary">&#128736;</div>
                <div class="fw-semibold">Hizmet Kalemleri</div>
                <div class="text-muted small">Hizmetlerde kullanılan parçalar</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="ServiceVisuals" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-danger bg-opacity-10 text-danger">&#128247;</div>
                <div class="fw-semibold">Hizmet Görselleri</div>
                <div class="text-muted small">Belgeler ve görseller</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Roles" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-primary bg-opacity-10 text-primary">&#128274;</div>
                <div class="fw-semibold">Roller</div>
                <div class="text-muted small">Kullanıcı rolleri ve yetkiler</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-controller="Users" asp-action="Index" class="card shadow-sm dash-card">
            <div class="card-body">
                <div class="dash-card-icon bg-success bg-opacity-10 text-success">&#128101;</div>
                <div class="fw-semibold">Kullanıcılar</div>
                <div class="text-muted small">Sistem kullanıcılarını yönetin</div>
            </div>
        </a>
    </div>
</div>

<p class="text-muted small mb-3">
    Üstteki sayılar <strong>tüm zamanlar</strong> özetidir. Her grafikteki dönem seçimi yalnızca o grafiği etkiler (filtre: servis <strong>alınma tarihi</strong>).
    Stok çubuğu güncel envanterdir; dönem seçimi yoktur.
</p>

<div class="row g-3 mb-2">
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Tamamlanan servisler</div>
                <div class="stat-value text-success">@Model.CompletedServices</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Tamamlanmayan servisler</div>
                <div class="stat-value text-warning">@Model.IncompleteServices</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Aktif müşteriler</div>
                <div class="stat-value text-primary">@Model.ActiveCustomers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Pasif müşteriler</div>
                <div class="stat-value text-secondary">@Model.InactiveCustomers</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">Toplam servis</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.TotalServices</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">İptal servis</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.CancelledServices</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">Toplam müşteri</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.TotalCustomers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">Toplam ürün</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.TotalItems</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">Servis kalemi satırı</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.TotalServiceItemLines</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card shadow-sm dash-stat-card h-100">
            <div class="card-body py-3">
                <div class="stat-label">Ödeme tamam / eksik (tümü)</div>
                <div class="stat-value" style="font-size:1.35rem">@Model.PaymentCompleteCount / @Model.PaymentIncompleteCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Tedarikçiye göre servislerde kullanılan parça (adet)</div>
                @await Html.PartialAsync("_DashboardRangeSelect", new DashboardRangeSelectViewModel { ParamName = "ru", SelectedKey = Model.RangeUsageKey })
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem: <strong>@Model.RangeUsageLabel</strong></p>
                @if (Model.SupplierUsageInServices.Count == 0)
                {
                    <p class="text-muted small mb-0">Bu dönemde servis kalemi yok.</p>
                }
                else
                {
                    <div class="dash-chart-wrap">
                        <canvas id="chartSupplierUsage"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Tedarikçiye göre stok miktarı (ürün adedi)</div>
                <span class="badge bg-secondary align-self-center">Güncel stok</span>
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem filtresi uygulanmaz.</p>
                @if (Model.SupplierStockQuantities.Count == 0)
                {
                    <p class="text-muted small mb-0">Ürün kaydı yok.</p>
                }
                else
                {
                    <div class="dash-chart-wrap">
                        <canvas id="chartSupplierStock"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Ödeme durumu</div>
                @await Html.PartialAsync("_DashboardRangeSelect", new DashboardRangeSelectViewModel { ParamName = "rp", SelectedKey = Model.RangePaymentKey })
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem: <strong>@Model.RangePaymentLabel</strong></p>
                <div class="dash-chart-wrap">
                    <canvas id="chartPayment"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Müşteri başına servis sayısı</div>
                @await Html.PartialAsync("_DashboardRangeSelect", new DashboardRangeSelectViewModel { ParamName = "rc", SelectedKey = Model.RangeCustomerKey })
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem: <strong>@Model.RangeCustomerLabel</strong></p>
                @if (Model.ServicesPerCustomer.Count == 0)
                {
                    <p class="text-muted small mb-0">Bu dönemde servis yok.</p>
                }
                else
                {
                    <div class="dash-chart-wrap">
                        <canvas id="chartCustomerServices"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Servis durum dağılımı</div>
                @await Html.PartialAsync("_DashboardRangeSelect", new DashboardRangeSelectViewModel { ParamName = "rs", SelectedKey = Model.RangeStatusKey })
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem: <strong>@Model.RangeStatusLabel</strong></p>
                @if (Model.ServicesByStatus.Count == 0)
                {
                    <p class="text-muted small mb-0">Bu dönemde servis yok.</p>
                }
                else
                {
                    <div class="dash-chart-wrap">
                        <canvas id="chartStatus"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card shadow-sm dash-chart-card h-100">
            <div class="card-header bg-transparent py-3 dash-chart-toolbar">
                <div class="dash-chart-toolbar-title fw-semibold">Alınan servisler</div>
                @await Html.PartialAsync("_DashboardRangeSelect", new DashboardRangeSelectViewModel { ParamName = "rt", SelectedKey = Model.RangeTimelineKey })
            </div>
            <div class="card-body pt-0">
                <p class="text-muted small mb-2 mb-md-3">Dönem: <strong>@Model.RangeTimelineLabel</strong> — @Model.TimelineChartDescription</p>
                <div class="dash-chart-wrap">
                    <canvas id="chartMonthly"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        (function () {
            var palette = ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6f42c1', '#fd7e14', '#20c997', '#6c757d'];
            function mapLabels(arr) { return arr.map(function (x) { return x.label; }); }
            function mapData(arr) { return arr.map(function (x) { return Number(x.value); }); }

            var supplierUsage = @Html.Raw(JsonSerializer.Serialize(Model.SupplierUsageInServices, jsonOptions));
            var supplierStock = @Html.Raw(JsonSerializer.Serialize(Model.SupplierStockQuantities, jsonOptions));
            var perCustomer = @Html.Raw(JsonSerializer.Serialize(Model.ServicesPerCustomer, jsonOptions));
            var byStatus = @Html.Raw(JsonSerializer.Serialize(Model.ServicesByStatus, jsonOptions));
            var monthly = @Html.Raw(JsonSerializer.Serialize(Model.ServicesReceivedTimeline, jsonOptions));
            var payComplete = @Model.PaymentCompleteInRange;
            var payIncomplete = @Model.PaymentIncompleteInRange;

            var commonOpts = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: true, position: 'bottom' } }
            };

            var elUsage = document.getElementById('chartSupplierUsage');
            if (elUsage && supplierUsage.length) {
                new Chart(elUsage, {
                    type: 'bar',
                    data: {
                        labels: mapLabels(supplierUsage),
                        datasets: [{
                            label: 'Adet',
                            data: mapData(supplierUsage),
                            backgroundColor: palette.map(function (c, i) { return c; })
                        }]
                    },
                    options: { ...commonOpts, indexAxis: 'y', plugins: { legend: { display: false } } }
                });
            }

            var elStock = document.getElementById('chartSupplierStock');
            if (elStock && supplierStock.length) {
                new Chart(elStock, {
                    type: 'bar',
                    data: {
                        labels: mapLabels(supplierStock),
                        datasets: [{
                            label: 'Stok adedi',
                            data: mapData(supplierStock),
                            backgroundColor: '#20c997'
                        }]
                    },
                    options: { ...commonOpts, indexAxis: 'y', plugins: { legend: { display: false } } }
                });
            }

            new Chart(document.getElementById('chartPayment'), {
                type: 'doughnut',
                data: {
                    labels: ['Ödeme tamam', 'Ödeme eksik'],
                    datasets: [{
                        data: [payComplete, payIncomplete],
                        backgroundColor: ['#198754', '#ffc107'],
                        borderWidth: 1
                    }]
                },
                options: commonOpts
            });

            var elCust = document.getElementById('chartCustomerServices');
            if (elCust && perCustomer.length) {
                new Chart(elCust, {
                    type: 'bar',
                    data: {
                        labels: mapLabels(perCustomer),
                        datasets: [{
                            label: 'Servis sayısı',
                            data: mapData(perCustomer),
                            backgroundColor: '#0d6efd'
                        }]
                    },
                    options: {
                        ...commonOpts,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { ticks: { maxRotation: 45, minRotation: 0, autoSkip: true, maxTicksLimit: 12 } }
                        }
                    }
                });
            }

            var elStatus = document.getElementById('chartStatus');
            if (elStatus && byStatus.length) {
                new Chart(elStatus, {
                    type: 'pie',
                    data: {
                        labels: mapLabels(byStatus),
                        datasets: [{
                            data: mapData(byStatus),
                            backgroundColor: byStatus.map(function (_, i) { return palette[i % palette.length]; }),
                            borderWidth: 1
                        }]
                    },
                    options: commonOpts
                });
            }

            var elMonth = document.getElementById('chartMonthly');
            if (elMonth && monthly.length) {
                new Chart(elMonth, {
                    type: 'line',
                    data: {
                        labels: mapLabels(monthly),
                        datasets: [{
                            label: 'Servis',
                            data: mapData(monthly),
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.12)',
                            fill: true,
                            tension: 0.25
                        }]
                    },
                    options: {
                        ...commonOpts,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
        })();
    </script>
}
