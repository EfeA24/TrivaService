@model ServiceVisuals
@{
    ViewData["Title"] = "Service Visual Details";
}

<div class="page-header">
    <h1>Service Visual Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.ServiceVisualName</dd>
            <dt class="col-sm-3">Service</dt><dd class="col-sm-9">@(Model.ServiceId?.ToString() ?? "—")</dd>
            <dt class="col-sm-3">Document URL</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.ServiceDocumentUrl))
                {
                    <a href="@Model.ServiceDocumentUrl" target="_blank" rel="noopener">@Model.ServiceDocumentUrl</a>
                }
                else
                {
                    <span>—</span>
                }
            </dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
            <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Updated</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
</div>
