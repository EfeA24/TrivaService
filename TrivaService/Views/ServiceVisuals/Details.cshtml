@model ServiceVisuals
@{
    ViewData["Title"] = "Servis Görseli Detayları";
}

<div class="page-header">
    <h1>Servis Görseli Detayları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Görsel Adı</dt><dd class="col-sm-9">@Model.ServiceVisualName</dd>
            <dt class="col-sm-3">Servis</dt><dd class="col-sm-9">@(Model.ServiceId?.ToString() ?? "—")</dd>
            <dt class="col-sm-3">Medya Dosyaları</dt>
            <dd class="col-sm-9">
                @{
                    var mediaLinks = (Model.ServiceDocumentUrl ?? string.Empty)
                        .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                }
                @if (mediaLinks.Length > 0)
                {
                    <ul class="mb-0 ps-3">
                        @for (var i = 0; i < mediaLinks.Length; i++)
                        {
                            <li><a href="@mediaLinks[i]" target="_blank" rel="noopener">Dosya @(i + 1)</a></li>
                        }
                    </ul>
                }
                else
                {
                    <span>—</span>
                }
            </dd>
            <dt class="col-sm-3">Notlar</dt><dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
            <dt class="col-sm-3">Oluşturma Tarihi</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Güncelleme Tarihi</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Aktif</span>
                }
                else
                {
                    <span class="badge-inactive">Pasif</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Düzenle</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Sil</a>
</div>
