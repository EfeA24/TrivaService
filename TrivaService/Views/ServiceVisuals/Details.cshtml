@model ServiceVisuals
@{
    ViewData["Title"] = "Service visual";
}
<h1>Service visual</h1>
<dl class="row">
    <dt class="col-sm-2">Id</dt><dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">ServiceId</dt><dd class="col-sm-10">@Model.ServiceId</dd>
    <dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.ServiceVisualName</dd>
    <dt class="col-sm-2">Document URL</dt><dd class="col-sm-10">@Model.ServiceDocumentUrl</dd>
    <dt class="col-sm-2">Notes</dt><dd class="col-sm-10">@Model.Notes</dd>
    <dt class="col-sm-2">Create</dt><dd class="col-sm-10">@Model.CreateDate</dd>
    <dt class="col-sm-2">Update</dt><dd class="col-sm-10">@Model.UpdateDate</dd>
    <dt class="col-sm-2">Active</dt><dd class="col-sm-10">@Model.IsActive</dd>
</dl>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</p>
