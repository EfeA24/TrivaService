@model ServiceVisuals
@{
    ViewData["Title"] = "Edit Service Visual";
}

<div class="page-header">
    <h1>Edit Service Visual</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm form-card">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ServiceId" class="form-label fw-semibold"></label>
                    <input asp-for="ServiceId" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ServiceVisualName" class="form-label fw-semibold"></label>
                    <input asp-for="ServiceVisualName" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Medya Dosyaları (Fotoğraf/Video)</label>
                    <input type="file" name="mediaFiles" class="form-control" accept="image/*,video/*" multiple />
                    <div class="form-text">Yeni dosya seçerseniz mevcut medya kayıtları güncellenir.</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.ServiceDocumentUrl))
                {
                    <div class="col-12">
                        <label class="form-label fw-semibold">Mevcut Medya</label>
                        <ul class="mb-0 ps-3">
                            @foreach (var mediaUrl in Model.ServiceDocumentUrl.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <li><a href="@mediaUrl" target="_blank" rel="noopener">@mediaUrl</a></li>
                            }
                        </ul>
                    </div>
                }
                <div class="col-12">
                    <label asp-for="Notes" class="form-label fw-semibold"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
