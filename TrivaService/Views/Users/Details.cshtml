@model Users
@{
    ViewData["Title"] = "User Details";
}

<div class="page-header">
    <h1>User Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Username</dt><dd class="col-sm-9">@Model.UserName</dd>
            <dt class="col-sm-3">Role</dt><dd class="col-sm-9">@Model.RolesId</dd>
            <dt class="col-sm-3">Phone</dt><dd class="col-sm-9">@(Model.UserPhone ?? "—")</dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@(Model.UserNotes ?? "—")</dd>
            <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Updated</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
</div>
