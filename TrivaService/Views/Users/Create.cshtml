@model Users
@{
    ViewData["Title"] = "Yeni Kullanıcı";
}

<div class="page-header">
    <h1>Yeni Kullanıcı</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm form-card">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="UserName" class="form-label fw-semibold">Kullanıcı Adı</label>
                    <input asp-for="UserName" class="form-control" autocomplete="username" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="RolesId" class="form-label fw-semibold">Rol</label>
                    <input asp-for="RolesId" class="form-control" />
                    <span asp-validation-for="RolesId" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="UserPasswordHash" class="form-label fw-semibold">Şifre</label>
                    <input asp-for="UserPasswordHash" class="form-control" type="password" autocomplete="new-password" />
                    <span asp-validation-for="UserPasswordHash" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="UserPhone" class="form-label fw-semibold">Telefon</label>
                    <input asp-for="UserPhone" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="UserNotes" class="form-label fw-semibold">Notlar</label>
                    <textarea asp-for="UserNotes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
