@model TrivaService.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Triva Service</title>
    <style>
            :root {
                --primary: #00A19B;
                --primary-hover: #008F8A;
                --primary-active: #007A75;
                --gradient-start: #0E5552;
                --gradient-mid: #0A4442;
                --gradient-end: #083738;
                --page-bg: #E4DDD3;
                --card-bg: #F2EDE6;
                --input-bg: #EBE4DA;
                --border-default: #D6CEC4;
                --border-light: #E8E3DC;
                --text-primary: #2F2F2F;
                --text-secondary: #6B6B6B;
                --text-muted: #9A9A9A;
                --white: #FFFFFF;
                --white-92: rgba(255,255,255,0.92);
                --white-65: rgba(255,255,255,0.65);
                --white-50: rgba(255,255,255,0.50);
                --white-25: rgba(255,255,255,0.25);
                --white-14: rgba(255,255,255,0.14);
                --white-07: rgba(255,255,255,0.07);
                --danger-text: #B02A37;
                --danger-bg: rgba(220, 53, 69, 0.08);
                --danger-border: rgba(220, 53, 69, 0.22);
                --shadow: rgba(47, 47, 47, 0.12);
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: Inter, Segoe UI, Arial, sans-serif;
            }

            body {
                min-height: 100vh;
                background: var(--page-bg);
                color: var(--text-primary);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 32px;
            }

            .login-wrapper {
                width: 100%;
                max-width: 1040px;
                min-height: 620px;
                display: grid;
                grid-template-columns: 1.05fr 0.95fr;
                background: var(--card-bg);
                border: 1px solid var(--border-default);
                border-radius: 28px;
                overflow: hidden;
                box-shadow: 0 24px 70px var(--shadow);
            }

            .brand-panel {
                position: relative;
                padding: 56px;
                background: radial-gradient(circle at top left, var(--white-14), transparent 36%), radial-gradient(circle at bottom right, var(--white-07), transparent 34%), linear-gradient(145deg, var(--gradient-start), var(--gradient-mid), var(--gradient-end));
                color: var(--white);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }

            .brand-panel::before,
            .brand-panel::after {
                content: "";
                position: absolute;
                border-radius: 50%;
                border: 1px solid var(--white-14);
                pointer-events: none;
            }

            .brand-panel::before {
                width: 260px;
                height: 260px;
                top: -80px;
                right: -70px;
                background: var(--white-07);
            }

            .brand-panel::after {
                width: 180px;
                height: 180px;
                bottom: 80px;
                left: -70px;
                background: var(--white-07);
            }

            .brand-content {
                position: relative;
                z-index: 1;
            }

            .brand-home-link {
                display: inline-flex;
                color: inherit;
                text-decoration: none;
            }

            .logo {
                width: 58px;
                height: 58px;
                border-radius: 18px;
                background: var(--white-14);
                border: 1px solid var(--white-25);
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 42px;
                box-shadow: inset 0 1px 0 var(--white-25);
                transition: transform 0.2s ease;
            }

            .brand-home-link:hover .logo {
                transform: translateY(-1px);
            }

            .logo span {
                width: 24px;
                height: 24px;
                border-radius: 8px;
                background: var(--primary);
                box-shadow: 0 0 0 8px var(--white-14);
            }

            .brand-panel h1 {
                font-size: 42px;
                line-height: 1.12;
                letter-spacing: -1.2px;
                margin-bottom: 18px;
                color: var(--white-92);
            }

            .brand-panel p {
                max-width: 420px;
                font-size: 16px;
                line-height: 1.8;
                color: var(--white-65);
            }

            .brand-footer {
                position: relative;
                z-index: 1;
                display: flex;
                gap: 14px;
                align-items: center;
                padding: 16px;
                border: 1px solid var(--white-14);
                background: var(--white-07);
                border-radius: 18px;
                color: var(--white-65);
                backdrop-filter: blur(10px);
            }

            .brand-footer-icon {
                width: 38px;
                height: 38px;
                border-radius: 14px;
                background: var(--white-14);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--white-92);
                font-weight: 700;
            }

            .form-panel {
                padding: 56px 52px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .form-card {
                width: 100%;
                max-width: 390px;
            }

            .form-card h2 {
                font-size: 32px;
                letter-spacing: -0.7px;
                margin-bottom: 10px;
                color: var(--text-primary);
            }

            .form-card .subtitle {
                color: var(--text-secondary);
                font-size: 15px;
                line-height: 1.6;
                margin-bottom: 34px;
            }

            .form-group {
                margin-bottom: 20px;
            }

            label {
                display: block;
                font-size: 14px;
                font-weight: 650;
                color: var(--text-primary);
                margin-bottom: 9px;
            }

            .input-box {
                position: relative;
            }

            input[type="text"],
            input[type="password"] {
                width: 100%;
                height: 52px;
                border: 1px solid var(--border-default);
                background: var(--input-bg);
                color: var(--text-primary);
                border-radius: 15px;
                padding: 0 16px;
                font-size: 15px;
                outline: none;
                transition: 0.2s ease;
            }

            input::placeholder {
                color: var(--text-muted);
            }

            input:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(0, 161, 155, 0.14);
                background: #F2EDE6;
            }

            .field-error {
                display: block;
                margin-top: 8px;
                font-size: 13px;
                color: var(--danger-text);
            }

            .options {
                display: flex;
                align-items: center;
                justify-content: flex-end;
                margin: 8px 0 24px;
                gap: 12px;
                font-size: 14px;
            }

            .forgot-link {
                color: var(--primary-active);
                text-decoration: none;
                font-weight: 650;
            }

            .forgot-link:hover {
                color: var(--primary-hover);
                text-decoration: underline;
            }

            .login-button {
                width: 100%;
                height: 54px;
                border: none;
                border-radius: 16px;
                background: var(--primary);
                color: var(--white);
                font-size: 16px;
                font-weight: 750;
                cursor: pointer;
                transition: 0.2s ease;
                box-shadow: 0 14px 30px rgba(0, 161, 155, 0.24);
            }

            .login-button:hover {
                background: var(--primary-hover);
                transform: translateY(-1px);
            }

            .login-button:active {
                background: var(--primary-active);
                transform: translateY(0);
            }

            .validation-box {
                margin-bottom: 16px;
                padding: 12px 14px;
                border-radius: 14px;
                color: var(--danger-text);
                background: var(--danger-bg);
                border: 1px solid var(--danger-border);
                font-size: 14px;
                line-height: 1.5;
            }

            .validation-box:empty {
                display: none;
            }

            .divider {
                display: flex;
                align-items: center;
                gap: 14px;
                margin: 28px 0;
                color: var(--text-muted);
                font-size: 13px;
            }

            .divider::before,
            .divider::after {
                content: "";
                flex: 1;
                height: 1px;
                background: var(--border-light);
            }

            .helper-links {
                display: flex;
                justify-content: space-between;
                gap: 8px;
                margin-top: 14px;
                font-size: 13px;
            }

            .helper-links a {
                color: var(--text-secondary);
                text-decoration: none;
            }

            .helper-links a:hover {
                color: var(--text-primary);
                text-decoration: underline;
            }

            @@media (max-width: 860px) {
                .login-wrapper {
                    grid-template-columns: 1fr;
                    max-width: 520px;
                }

                .brand-panel {
                    min-height: 320px;
                    padding: 38px;
                }

                .brand-panel h1 {
                    font-size: 32px;
                }

                .brand-footer {
                    margin-top: 34px;
                }

                .form-panel {
                    padding: 42px 30px;
                }
            }

            @@media (max-width: 480px) {
                body {
                    padding: 18px;
                }

                .brand-panel,
                .form-panel {
                    padding: 30px 22px;
                }

                .helper-links {
                    flex-direction: column;
                    align-items: center;
                }
            }
    </style>
</head>
<body>
    <main class="login-wrapper">
        <section class="brand-panel">
            <div class="brand-content">
                <a class="brand-home-link" asp-controller="Home" asp-action="Index" aria-label="Ana sayfaya git">
                    <div class="logo" aria-hidden="true">
                        <span></span>
                    </div>
                </a>

                <h1>Yönetim paneline hoş geldiniz.</h1>
                <p>
                    Güvenli, sade ve modern bir giriş deneyimi. Marka renkleriyle uyumlu,
                    kurumsal ve temiz bir arayüz.
                </p>
            </div>

            <div class="brand-footer">
                <div class="brand-footer-icon">✓</div>
                <div>
                    <strong style="color: var(--white-92); display:block; margin-bottom:3px;">Güvenli Erişim</strong>
                    <span>Yetkili kullanıcı girişi</span>
                </div>
            </div>
        </section>

        <section class="form-panel">
            <form class="form-card" asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }

                <h2>Giriş Yap</h2>
                <p class="subtitle">Hesabınıza erişmek için kullanıcı bilgilerinizi girin.</p>

                <div asp-validation-summary="ModelOnly" class="validation-box"></div>

                <div class="form-group">
                    <label asp-for="UserName"></label>
                    <div class="input-box">
                        <input asp-for="UserName" type="text" autocomplete="username" placeholder="Kullanıcı adınızı girin" />
                    </div>
                    <span asp-validation-for="UserName" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password"></label>
                    <div class="input-box">
                        <input asp-for="Password" type="password" autocomplete="current-password" placeholder="Parolanızı girin" />
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="options">
                    <a class="forgot-link" href="mailto:destek@triva.local?subject=Parola%20S%C4%B1f%C4%B1rlama%20Talebi">Şifremi unuttum</a>
                </div>

                <button class="login-button" type="submit">Giriş Yap</button>

                <div class="helper-links">
                    <a asp-controller="Home" asp-action="Index">Ana sayfa</a>
                    <a asp-controller="Home" asp-action="Privacy">Gizlilik</a>
                </div>
            </form>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
