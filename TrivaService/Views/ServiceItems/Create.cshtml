@model ServiceItem
@{
    ViewData["Title"] = "New Service Item";
}

<div class="page-header">
    <h1>New Service Item</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Back</a>
</div>

<div class="card shadow-sm form-card">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ServiceId" class="form-label fw-semibold"></label>
                    <input asp-for="ServiceId" class="form-control" />
                    <span asp-validation-for="ServiceId" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="ItemId" class="form-label fw-semibold"></label>
                    <input asp-for="ItemId" class="form-control" />
                    <span asp-validation-for="ItemId" class="text-danger small"></span>
                </div>
                <div class="col-sm-4">
                    <label asp-for="Quantity" class="form-label fw-semibold"></label>
                    <input asp-for="Quantity" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="UnitPrice" class="form-label fw-semibold"></label>
                    <input asp-for="UnitPrice" class="form-control" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="UnitCost" class="form-label fw-semibold"></label>
                    <input asp-for="UnitCost" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="TotalPrice" class="form-label fw-semibold"></label>
                    <input asp-for="TotalPrice" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label fw-semibold"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
