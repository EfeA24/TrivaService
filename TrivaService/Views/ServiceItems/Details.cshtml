@model ServiceItem
@{
    ViewData["Title"] = "Servis Kalemi Detayları";
}

<div class="page-header">
    <h1>Servis Kalemi Detayları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-4">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Servis</dt><dd class="col-sm-9">@Model.ServiceId</dd>
            <dt class="col-sm-3">Ürün</dt><dd class="col-sm-9">@Model.ItemId</dd>
            <dt class="col-sm-3">Adet</dt><dd class="col-sm-9">@Model.Quantity</dd>
            <dt class="col-sm-3">Birim Fiyat</dt><dd class="col-sm-9">@(Model.UnitPrice?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Birim Maliyet</dt><dd class="col-sm-9">@(Model.UnitCost?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Toplam Fiyat</dt><dd class="col-sm-9">@(Model.TotalPrice?.ToString("C") ?? "—")</dd>
            <dt class="col-sm-3">Notlar</dt><dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
            <dt class="col-sm-3">Oluşturma Tarihi</dt><dd class="col-sm-9">@Model.CreateDate.ToString("g")</dd>
            <dt class="col-sm-3">Güncelleme Tarihi</dt><dd class="col-sm-9">@Model.UpdateDate.ToString("g")</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge-active">Aktif</span>
                }
                else
                {
                    <span class="badge-inactive">Pasif</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Düzenle</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Sil</a>
</div>
