@model TrivaService.ViewModels.Permissions.RoleEditViewModel
@{
    ViewData["Title"] = "Yeni Rol";
}

<div class="page-header">
    <h1>Yeni Rol</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Geri</a>
</div>

<div class="card shadow-sm form-card">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="RoleName" class="form-label fw-semibold">Rol Adı</label>
                    <input asp-for="RoleName" class="form-control" />
                    <span asp-validation-for="RoleName" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="RoleDescription" class="form-label fw-semibold">Açıklama</label>
                    <textarea asp-for="RoleDescription" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Aktif</label>
                    </div>
                </div>
            </div>
            <hr class="my-4" />
            <h5 class="mb-3">Yetkilendirmeler</h5>
            <div class="accordion" id="permissionAccordion">
                @for (var i = 0; i < Model.Permissions.Count; i++)
                {
                    var entity = Model.Permissions[i];
                    <div class="accordion-item mb-2 border rounded">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#entity_@i">
                                @entity.EntityName
                            </button>
                        </h2>
                        <div id="entity_@i" class="accordion-collapse collapse">
                            <div class="accordion-body">
                                <input type="hidden" asp-for="Permissions[i].EntityName" />
                                <div class="row g-3 mb-3">
                                    <div class="col-md-3 form-check">
                                        <input asp-for="Permissions[i].CanRead" class="form-check-input" />
                                        <label asp-for="Permissions[i].CanRead" class="form-check-label">Okuyabilir</label>
                                    </div>
                                    <div class="col-md-3 form-check">
                                        <input asp-for="Permissions[i].CanCreate" class="form-check-input" />
                                        <label asp-for="Permissions[i].CanCreate" class="form-check-label">Oluşturabilir</label>
                                    </div>
                                    <div class="col-md-3 form-check">
                                        <input asp-for="Permissions[i].CanUpdate" class="form-check-input" />
                                        <label asp-for="Permissions[i].CanUpdate" class="form-check-label">Güncelleyebilir</label>
                                    </div>
                                    <div class="col-md-3 form-check">
                                        <input asp-for="Permissions[i].CanDelete" class="form-check-input" />
                                        <label asp-for="Permissions[i].CanDelete" class="form-check-label">Silebilir</label>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Alan</th>
                                                <th class="text-center">Görüntüle</th>
                                                <th class="text-center">Düzenle</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var j = 0; j < entity.Properties.Count; j++)
                                            {
                                                <tr>
                                                    <td>
                                                        @entity.Properties[j].PropertyName
                                                        <input type="hidden" asp-for="Permissions[i].Properties[j].PropertyName" />
                                                    </td>
                                                    <td class="text-center">
                                                        <input asp-for="Permissions[i].Properties[j].CanRead" class="form-check-input" />
                                                    </td>
                                                    <td class="text-center">
                                                        <input asp-for="Permissions[i].Properties[j].CanWrite" class="form-check-input" />
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Rolu Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
