@model Roles
@{
    ViewData["Title"] = "Role";
}
<h1>Role</h1>
<dl class="row">
    <dt class="col-sm-2">Id</dt><dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.RoleName</dd>
    <dt class="col-sm-2">Description</dt><dd class="col-sm-10">@Model.RoleDescription</dd>
    <dt class="col-sm-2">Create</dt><dd class="col-sm-10">@Model.CreateDate</dd>
    <dt class="col-sm-2">Update</dt><dd class="col-sm-10">@Model.UpdateDate</dd>
    <dt class="col-sm-2">Active</dt><dd class="col-sm-10">@Model.IsActive</dd>
</dl>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</p>
