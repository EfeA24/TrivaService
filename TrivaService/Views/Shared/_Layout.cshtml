<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrivaService</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrivaService.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <nav class="sidebar" id="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">T</span>
                TrivaService
            </a>
            <div class="sidebar-menu">
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                </div>
                <div class="menu-section">Service</div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Customers" asp-action="Index">Customers</a>
                </div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Services" asp-action="Index">Services</a>
                </div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="ServiceItems" asp-action="Index">Service Items</a>
                </div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="ServiceVisuals" asp-action="Index">Service Visuals</a>
                </div>
                <div class="menu-section">Stock</div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Items" asp-action="Index">Items</a>
                </div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Suppliers" asp-action="Index">Suppliers</a>
                </div>
                <div class="menu-section">Admin</div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Roles" asp-action="Index">Roles</a>
                </div>
                <div class="menu-item">
                    <a class="menu-link" asp-controller="Users" asp-action="Index">Users</a>
                </div>
            </div>
            <div class="sidebar-footer">
                &copy; 2026 TrivaService
            </div>
        </nav>

        <div class="main-area">
            <header class="topbar">
                <button class="topbar-toggle" id="sidebarToggle" type="button">&#9776;</button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </header>
            <main class="page-content">
                @RenderBody()
            </main>
            <footer class="page-footer">
                &copy; 2026 TrivaService &mdash;
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </footer>
        </div>
    </div>

    <div class="sidebar-overlay d-md-none" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var btn = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (btn && sidebar) {
                btn.addEventListener('click', function () {
                    sidebar.classList.toggle('show');
                    overlay.classList.toggle('show');
                });
                overlay.addEventListener('click', function () {
                    sidebar.classList.remove('show');
                    overlay.classList.remove('show');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
