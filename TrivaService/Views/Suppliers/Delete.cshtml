@model Supplier
@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="page-header">
    <h1 class="text-danger">Delete Supplier</h1>
</div>

<div class="card border-danger shadow-sm" style="max-width: 560px;">
    <div class="card-header bg-danger text-white fw-semibold">
        This action cannot be undone. Are you sure?
    </div>
    <div class="card-body">
        <dl class="row detail-dl mb-0">
            <dt class="col-sm-4">ID</dt><dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.SupplierName</dd>
            <dt class="col-sm-4">Phone</dt><dd class="col-sm-8">@(Model.SupplierPhone ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer bg-transparent d-flex gap-2">
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
