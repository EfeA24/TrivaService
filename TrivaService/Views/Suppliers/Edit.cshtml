@model Supplier
@{
    ViewData["Title"] = "Edit supplier";
}
<h1>Edit supplier</h1>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="SupplierName" class="form-label"></label>
        <input asp-for="SupplierName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupplierPhone" class="form-label"></label>
        <input asp-for="SupplierPhone" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupplierContactPerson" class="form-label"></label>
        <input asp-for="SupplierContactPerson" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupplierEmail" class="form-label"></label>
        <input asp-for="SupplierEmail" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupplierAddress" class="form-label"></label>
        <textarea asp-for="SupplierAddress" class="form-control"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
